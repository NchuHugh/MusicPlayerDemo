<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutNotificationPlayer"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@android:color/transparent"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="8dp">

    <ImageView
        android:id="@+id/ivNotificationCover"
        android:layout_width="48dp"
        android:layout_height="48dp"
     
        android:contentDescription="当前歌曲封面"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_media_play" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNotificationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="未选择歌曲"
            android:textColor="#202124"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotificationArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="点击列表开始播放"
            android:textColor="#7A7F87"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnNotificationPrevious"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:contentDescription="上一首"
        android:src="@android:drawable/ic_media_previous" />

    <ImageButton
        android:id="@+id/btnNotificationPlayPause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:contentDescription="播放或暂停"
        android:src="@android:drawable/ic_media_play" />

    <ImageButton
        android:id="@+id/btnNotificationNext"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:contentDescription="下一首"
        android:src="@android:drawable/ic_media_next" />

</LinearLayout>
